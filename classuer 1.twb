      <column caption='% Profit' datatype='real' default-format='p0.00%' name='[Calculation_0081671800848386]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Montant des ventes])' />
      </column>
      <column caption='5% eco-tax' datatype='real' name='[Calculation_0081671820816388]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Catégorie] = &quot;Produits technologiques&quot;&#13;&#10;THEN [Profit] * 0.05&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Calculation1' datatype='boolean' name='[Calculation_0081671925927942]' role='measure' type='nominal'>
        <calculation class='tableau' formula='SUM([Montant des ventes]) &lt; 1000' />
      </column>
      <column caption='%proffit' datatype='real' name='[Calculation_0081671944126471]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Profit] * (1 + [Parameters].[Parameter 1])' />
      </column>
      <column caption='Panier moyen' datatype='real' name='[Calculation_0081672186925064]' role='measure' type='quantitative'>
